# режим логирования для gin и эндпоинтов
# debug/release
GIN_MODE=debug

# порт сервера принятия решений и доступа к бд
DECISION_SERVER_PORT=8080
CRUD_SERVER_PORT=8081

# устанавливает решение по умолчанию 
# для ситуаций, когда для конкретного сервиса не существует политики или правила
# true/false 
DEFAULT_DECISION=true 

# версия api
API_VERSION=1

# JWT_SECRET_KEY=12345

# конфигурация бд
DB_HOST=clipe_db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=clipe